<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0A0A0F"/>
      <stop offset="100%" style="stop-color:#1A1A2E"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#F7931A"/>
      <stop offset="50%" style="stop-color:#EA580C"/>
      <stop offset="100%" style="stop-color:#FFD600"/>
    </linearGradient>
    <pattern id="grid" width="50" height="50" patternUnits="userSpaceOnUse">
      <path d="M 50 0 L 0 0 0 50" fill="none" stroke="rgba(247,147,26,0.05)" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect width="1200" height="630" fill="url(#grid)"/>
  <circle cx="1100" cy="100" r="300" fill="url(#accent)" opacity="0.05"/>
  <circle cx="100" cy="500" r="200" fill="url(#accent)" opacity="0.03"/>
  <text x="600" y="240" text-anchor="middle" font-family="system-ui" font-size="56" font-weight="bold" fill="white">
    Polypulse<tspan fill="#F7931A">News</tspan>
  </text>
  <text x="600" y="310" text-anchor="middle" font-family="system-ui" font-size="28" fill="#A0A0B5">
    Prediction Market Intelligence
  </text>
  <text x="600" y="370" text-anchor="middle" font-family="monospace" font-size="20" fill="#666">
    Polymarket â¢ Kalshi â¢ Real-time Analytics
  </text>
  <rect x="450" y="410" width="300" height="3" fill="url(#accent)" rx="2"/>
  <text x="600" y="460" text-anchor="middle" font-family="monospace" font-size="16" fill="#888">
    www.polypulsenews.live
  </text>
</svg>
